# Server
PORT=4021
BASE_URL=http://localhost:4021
WEB_APP_URL=http://localhost:5173
# Comma-separated browser origins allowed in production (defaults to WEB_APP_URL)
# ALLOWED_ORIGINS=https://your-web-app.example.com,http://localhost:5173

# Stellar / x402
# Select deployment network: testnet (default) or mainnet. Individual vars below may override presets.
STELLAR_NETWORK=testnet
NETWORK=stellar:testnet
FACILITATOR_URL=https://www.x402.org/facilitator
PAY_TO=G...                           # Platform Stellar wallet (receives verification fees)
AGENT_SECRET_KEY=S...                 # Platform agent secret key (pays for verification)
# Soroban USDC SAC for the selected network (auto-filled from STELLAR_NETWORK if omitted)
USDC_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# Soroban / vault-registry
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org   # Stellar testnet Soroban RPC
VAULT_REGISTRY_CONTRACT_ID=CDQKUIADLO5S5WEHEUTTXX2M45WAHVRU2PBEBD6ZGDKMOP5A72FJ3OD4   # Deployed vault-registry on testnet (see contract/README.md)

# OpenRouter (AI verification)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Supabase
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=resources

# Limits
MAX_FILE_SIZE_MB=50
VERIFICATION_PRICE=0.10

# Rate limiting (verify-content + publish)
RATE_LIMIT_VERIFY_IP_MAX=10
RATE_LIMIT_VERIFY_IP_WINDOW_MS=60000
RATE_LIMIT_VERIFY_WALLET_MAX=5
RATE_LIMIT_VERIFY_WALLET_WINDOW_MS=3600000
RATE_LIMIT_PUBLISH_IP_MAX=20
RATE_LIMIT_PUBLISH_IP_WINDOW_MS=60000
RATE_LIMIT_PUBLISH_WALLET_MAX=10
RATE_LIMIT_PUBLISH_WALLET_WINDOW_MS=3600000

# Resilience
REQUEST_TIMEOUT_MS=30000              # Per-request timeout; slow upstreams return 503
GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000    # Max drain time for in-flight requests on shutdown
IDEMPOTENCY_TTL_MS=86400000           # How long a publish Idempotency-Key is remembered (24h)
CATALOG_CACHE_TTL_MS=10000            # Short-lived cache TTL for catalog/preview reads

# Soroban registry
REGISTRY_CONTRACT_ID=C...                # Same as VAULT_REGISTRY_CONTRACT_ID
REGISTRY_SECRET_KEY=S...                 # Secret key of the registry deployer / owner account

# ── Mainnet example (uncomment and replace placeholders) ─────────────────────
# STELLAR_NETWORK=mainnet
# NETWORK=stellar:pubnet
# SOROBAN_RPC_URL=https://soroban.stellar.org
# USDC_CONTRACT_ID=CCW67TSZV3SSS2HXMBQ5JFGCKJNXKZM7UQUWUZPUTHXSTZLEO7SJMI75
# VAULT_REGISTRY_CONTRACT_ID=C...        # Your mainnet vault-registry deployment
# REGISTRY_CONTRACT_ID=C...                # Same as VAULT_REGISTRY_CONTRACT_ID
# PAY_TO=G...                              # Mainnet-funded platform wallet
# AGENT_SECRET_KEY=S...                    # Mainnet-funded agent wallet
# REGISTRY_SECRET_KEY=S...                 # Mainnet registry owner secret
