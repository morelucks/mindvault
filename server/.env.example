# Server
PORT=4021
BASE_URL=http://localhost:4021

# Stellar / x402
NETWORK=stellar:testnet
FACILITATOR_URL=https://www.x402.org/facilitator
PAY_TO=G...                           # Platform Stellar wallet (receives verification fees)
AGENT_SECRET_KEY=S...                 # Platform agent secret key (pays for verification)

# OpenRouter (AI verification)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Supabase
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=resources

# Limits
MAX_FILE_SIZE_MB=50
VERIFICATION_PRICE=0.10

# Soroban registry
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
REGISTRY_CONTRACT_ID=C...                # Deployed vault-registry contract ID
REGISTRY_SECRET_KEY=S...                 # Secret key of the registry deployer / owner account
